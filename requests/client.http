@baseUrl = http://localhost:3000

# ══════════════════════════════════════════════════════
#  CLIENTES — requiere token con empresa asignada
#  Si usaste "npm run seed", el token del login ya incluye empresa
# ══════════════════════════════════════════════════════

# Token obtenido del login (paso 5 de auth.http)
@token = PEGA_EL_TOKEN_AQUI

# ID de un cliente — rellénalo después de crear uno en el paso 1
@clientId = bbb000000000000000000001

# ──────────────────────────────────────────────────────
# CRUD BÁSICO
# ──────────────────────────────────────────────────────

### 1. Crear cliente
# → Copia el "_id" de la respuesta y pégalo en @clientId arriba
POST {{baseUrl}}/api/client
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Construcciones López SL",
  "cif": "A87654321",
  "email": "lopez@construcciones.com",
  "address": {
    "street": "Calle Industria 10",
    "city": "Madrid",
    "postal": "28001"
  }
}

### 2. Listar todos los clientes
GET {{baseUrl}}/api/client
Authorization: Bearer {{token}}

### 3. Buscar por nombre (búsqueda parcial, sin distinción de mayúsculas)
GET {{baseUrl}}/api/client?name=lopez
Authorization: Bearer {{token}}

### 4. Búsqueda full-text (requiere índice de texto en BD)
GET {{baseUrl}}/api/client?search=construcciones
Authorization: Bearer {{token}}

### 5. Paginación — página 2, 5 resultados por página
GET {{baseUrl}}/api/client?page=2&limit=5
Authorization: Bearer {{token}}

### 6. Obtener cliente por ID
GET {{baseUrl}}/api/client/{{clientId}}
Authorization: Bearer {{token}}

### 7. Actualizar cliente
PUT {{baseUrl}}/api/client/{{clientId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Construcciones López SL (actualizado)",
  "email": "nuevo@lopezsl.com"
}

# ──────────────────────────────────────────────────────
# SOFT DELETE Y RESTAURACIÓN
# ──────────────────────────────────────────────────────

### 8. Archivar cliente (soft delete — se puede restaurar)
DELETE {{baseUrl}}/api/client/{{clientId}}?soft=true
Authorization: Bearer {{token}}

### 9. Ver clientes archivados
GET {{baseUrl}}/api/client/archived
Authorization: Bearer {{token}}

### 10. Restaurar cliente archivado
PATCH {{baseUrl}}/api/client/{{clientId}}/restore
Authorization: Bearer {{token}}

### 11. Eliminar definitivamente (hard delete — no se puede recuperar)
DELETE {{baseUrl}}/api/client/{{clientId}}
Authorization: Bearer {{token}}
