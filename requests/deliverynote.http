@baseUrl = http://localhost:3000

# ══════════════════════════════════════════════════════
#  ALBARANES — requiere token + clienteId + proyectoId
#
#  Si usaste "npm run seed", la BD ya tiene datos.
#  Haz login con demo@bildyapp.com / Password1 y obtén
#  los IDs desde GET /api/client y GET /api/project
# ══════════════════════════════════════════════════════

@token     = PEGA_EL_TOKEN_AQUI
@clientId  = PEGA_EL_ID_DEL_CLIENTE
@projectId = ccc000000000000000000001
@noteId    = ddd000000000000000000001

# ──────────────────────────────────────────────────────
# CREAR ALBARANES
# ──────────────────────────────────────────────────────

### 1. Crear albarán de HORAS
# → Copia el "_id" de la respuesta y pégalo en @noteId arriba
POST {{baseUrl}}/api/deliverynote
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "client": "{{clientId}}",
  "project": "{{projectId}}",
  "format": "hours",
  "hours": 8,
  "description": "Instalación eléctrica planta baja",
  "workdate": "2026-05-07",
  "workers": [
    { "name": "Juan García", "hours": 4 },
    { "name": "Pedro López", "hours": 4 }
  ]
}

### 2. Crear albarán de MATERIAL
POST {{baseUrl}}/api/deliverynote
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "client": "{{clientId}}",
  "project": "{{projectId}}",
  "format": "material",
  "material": "Cable eléctrico NYM 3×2.5mm 200m + canaletas PVC + caja Schneider",
  "description": "Material instalación eléctrica",
  "workdate": "2026-05-07"
}

# ──────────────────────────────────────────────────────
# LISTAR Y FILTRAR
# ──────────────────────────────────────────────────────

### 3. Listar todos los albaranes
GET {{baseUrl}}/api/deliverynote
Authorization: Bearer {{token}}

### 4. Solo albaranes FIRMADOS
GET {{baseUrl}}/api/deliverynote?signed=true
Authorization: Bearer {{token}}

### 5. Solo albaranes PENDIENTES de firma
GET {{baseUrl}}/api/deliverynote?signed=false
Authorization: Bearer {{token}}

### 6. Filtrar por rango de fechas
GET {{baseUrl}}/api/deliverynote?from=2026-04-01&to=2026-05-07
Authorization: Bearer {{token}}

### 7. Filtrar por cliente
GET {{baseUrl}}/api/deliverynote?client={{clientId}}
Authorization: Bearer {{token}}

### 8. Filtrar por formato (material u hours)
GET {{baseUrl}}/api/deliverynote?format=hours
Authorization: Bearer {{token}}

### 9. Combinar filtros — pendientes de firma de un cliente concreto
GET {{baseUrl}}/api/deliverynote?client={{clientId}}&signed=false
Authorization: Bearer {{token}}

### 10. Obtener albarán por ID (con datos de cliente y proyecto)
GET {{baseUrl}}/api/deliverynote/{{noteId}}
Authorization: Bearer {{token}}

# ──────────────────────────────────────────────────────
# FIRMA — requiere Postman o Thunder Client (no REST Client)
#   Method: PATCH
#   URL:    {{baseUrl}}/api/deliverynote/{{noteId}}/sign
#   Header: Authorization: Bearer {{token}}
#   Body:   form-data → campo "image" → selecciona un PNG o JPG
#   Resultado: la firma se sube a Cloudinary y el albarán queda firmado
# ──────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────
# PDF Y ELIMINACIÓN
# ──────────────────────────────────────────────────────

### 11. Descargar PDF del albarán
# Si está firmado, el PDF incluye la imagen de la firma
GET {{baseUrl}}/api/deliverynote/{{noteId}}/pdf
Authorization: Bearer {{token}}

### 12. Eliminar albarán (solo funciona si NO está firmado)
DELETE {{baseUrl}}/api/deliverynote/{{noteId}}
Authorization: Bearer {{token}}
