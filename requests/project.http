@baseUrl = http://localhost:3000

# ─────────────────────────────────────────
# ANTES DE EMPEZAR: necesitas token y clientId del paso anterior
# ─────────────────────────────────────────
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJfaWQiOiI2OWZiOWZmOTBmOTM4MTdjMmJkZDJiYjQiLCJyb2xlIjoiYWRtaW4iLCJpYXQiOjE3NzgwOTgzMjYsImV4cCI6MTc3ODA5OTIyNn0.1bM2L3j8dL3suXh5ZpOAymo87K4eOzIs009HemEE3ms
@clientId = 69fba1430f93817c2bdd2bca

# Después de crear el proyecto, copia su "_id" aquí
@projectId = 69fba1d90f93817c2bdd2bdd

# ─────────────────────────────────────────
# PASO 1: Crear proyecto (asociado al cliente)
# Después: copia el "_id" del proyecto y ponlo en @projectId arriba
# ─────────────────────────────────────────

### 1. Crear proyecto
POST {{baseUrl}}/api/project
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Reforma Oficina Central",
  "projectCode": "PROY-001",
  "client": "{{clientId}}",
  "address": {
    "street": "Gran Vía 45",
    "city": "Madrid",
    "postal": "28013"
  },
  "email": "obra@reforma.com",
  "notes": "Reforma completa planta baja"
}

### 2. Listar proyectos
GET {{baseUrl}}/api/project
Authorization: Bearer {{token}}

### 3. Filtrar proyectos activos
GET {{baseUrl}}/api/project?active=true
Authorization: Bearer {{token}}

### 4. Obtener proyecto por ID
GET {{baseUrl}}/api/project/{{projectId}}
Authorization: Bearer {{token}}

### 5. Actualizar proyecto
PUT {{baseUrl}}/api/project/{{projectId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Reforma Oficina Central (v2)",
  "notes": "Incluye pintura y electricidad"
}

### 6. Archivar proyecto (soft delete)
DELETE {{baseUrl}}/api/project/{{projectId}}?soft=true
Authorization: Bearer {{token}}

### 7. Ver proyectos archivados
GET {{baseUrl}}/api/project/archived
Authorization: Bearer {{token}}

### 8. Restaurar proyecto
PATCH {{baseUrl}}/api/project/{{projectId}}/restore
Authorization: Bearer {{token}}
