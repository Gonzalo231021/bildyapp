@baseUrl = http://localhost:3000

# ══════════════════════════════════════════════════════
#  PROYECTOS — requiere token con empresa + un clienteId
# ══════════════════════════════════════════════════════

@token     = PEGA_EL_TOKEN_AQUI
@clientId  = PEGA_EL_ID_DEL_CLIENTE   # de client.http paso 1
@projectId = PEGA_EL_ID_DEL_PROYECTO  # de este fichero paso 1

# ──────────────────────────────────────────────────────
# CRUD BÁSICO
# ──────────────────────────────────────────────────────

### 1. Crear proyecto
# → Copia el "_id" de la respuesta y pégalo en @projectId arriba
POST {{baseUrl}}/api/project
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Reforma Oficina Central",
  "projectCode": "PROY-001",
  "client": "{{clientId}}",
  "address": {
    "street": "Gran Vía 45",
    "city": "Madrid",
    "postal": "28013"
  },
  "email": "obra@reforma.com",
  "notes": "Reforma completa planta baja"
}

### 2. Listar todos los proyectos
GET {{baseUrl}}/api/project
Authorization: Bearer {{token}}

### 3. Filtrar proyectos activos
GET {{baseUrl}}/api/project?active=true
Authorization: Bearer {{token}}

### 4. Filtrar por nombre
GET {{baseUrl}}/api/project?name=reforma
Authorization: Bearer {{token}}

### 5. Filtrar por cliente
GET {{baseUrl}}/api/project?client={{clientId}}
Authorization: Bearer {{token}}

### 6. Obtener proyecto por ID
GET {{baseUrl}}/api/project/{{projectId}}
Authorization: Bearer {{token}}

### 7. Actualizar proyecto
PUT {{baseUrl}}/api/project/{{projectId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Reforma Oficina Central (v2)",
  "notes": "Incluye pintura, electricidad y climatización"
}

# ──────────────────────────────────────────────────────
# SOFT DELETE Y RESTAURACIÓN
# ──────────────────────────────────────────────────────

### 8. Archivar proyecto (soft delete)
DELETE {{baseUrl}}/api/project/{{projectId}}?soft=true
Authorization: Bearer {{token}}

### 9. Ver proyectos archivados
GET {{baseUrl}}/api/project/archived
Authorization: Bearer {{token}}

### 10. Restaurar proyecto archivado
PATCH {{baseUrl}}/api/project/{{projectId}}/restore
Authorization: Bearer {{token}}

### 11. Eliminar definitivamente
DELETE {{baseUrl}}/api/project/{{projectId}}
Authorization: Bearer {{token}}
