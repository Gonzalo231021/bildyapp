{
  "name": "bildyapp",
  "version": "1.0.0",
  "description": "API para gestión de albaranes de obra",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "node --env-file=.env src/index.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "seed": "node --env-file=.env src/utils/seed.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Gonzalo Martínez Fernández",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.817.0",
    "@slack/webhook": "^7.0.8",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.6.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "morgan-body": "^2.6.9",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.3",
    "pdfkit": "^0.16.0",
    "sharp": "^0.34.2",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.1.0"
  }
}
